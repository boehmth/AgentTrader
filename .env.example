# Copy to .env and fill in.
# Which LLM provider to use.
#   gemini = Google Gemini (needs GOOGLE_API_KEY)
#   sap    = SAP GenAI Hub on BTP (needs a service key JSON, see below)
LLM_PROVIDER=sap

# --- Provider: gemini ---
GOOGLE_API_KEY=

# Optional: override the default model.
# GEMINI_MODEL=models/gemini-flash-latest

# --- Provider: sap ---
# Path to the BTP service key JSON file (keep this file OUT of git!).
SAP_GENAI_SERVICE_KEY_FILE=./sap_service_key.json

# Model to use. Must be a running deployment in your AI Core resource group.
# Common values: gemini-1.5-pro, gemini-1.5-flash, gpt-4o-mini, gpt-4o,
#                anthropic--claude-3-haiku, anthropic--claude-3.5-sonnet
SAP_GENAI_MODEL=gemini-1.5-flash

# Resource group inside AI Core (usually 'default').
SAP_GENAI_RESOURCE_GROUP=default

# --- Prompts ---
# Which prompt version the runner should use.
# Reads from prompts/<PROMPT_VERSION>/system_prompt.txt and tool_descriptions.txt
PROMPT_VERSION=v1

# --- Ticker universe ---
# Comma-separated list. Empty -> default: NVDA,MSFT,SAP,AMZN
# The prompts should list the same tickers, otherwise the agent won't
# recognise them.
TICKERS=NVDA,MSFT,SAP,AMZN
